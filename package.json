{
  "name": "@litools/instancer",
  "version": "0.5.0",
  "description": "Stable IDs, pooling, picking, visibility, metadata, and batch updates for Babylon Lite instances.",
  "homepage": "https://instancer.babylonpress.org/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eldinor/lite-instancer.git"
  },
  "bugs": {
    "url": "https://github.com/eldinor/lite-instancer/issues"
  },
  "keywords": [
    "babylonjs",
    "babylon-lite",
    "babylonjs-lite",
    "thin-instances",
    "instancing",
    "instance-pool",
    "picking",
    "vat",
    "vertex-animation-texture",
    "webgl",
    "webgpu",
    "3d"
  ],
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Andrei Stepanov",
    "email": "eldinor@gmail.com",
    "url": "https://babylonpress.org/"
  },
  "sideEffects": false,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./vat": {
      "types": "./dist/vat.d.ts",
      "import": "./dist/vat.js"
    },
    "./animation": {
      "types": "./dist/animation.d.ts",
      "import": "./dist/animation.js"
    },
    "./vat-sockets": {
      "types": "./dist/vat-sockets.d.ts",
      "import": "./dist/vat-sockets.js"
    },
    "./outline": {
      "types": "./dist/outline.d.ts",
      "import": "./dist/outline.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "docs/README.md",
    "README.md",
    "User_Guide.md"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:examples": "npm run build && vite build --config vite.examples.config.ts",
    "docs": "typedoc",
    "dev": "vite --host 0.0.0.0",
    "preview:examples": "vite preview --host 0.0.0.0 --outDir examples-dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "peerDependencies": {
    "@babylonjs/lite": "^1.11.0"
  },
  "peerDependenciesMeta": {
    "@babylonjs/lite": {
      "optional": false
    }
  },
  "devDependencies": {
    "@babylonjs/lite": "^1.11.0",
    "@preact/signals": "^2.9.3",
    "@webgpu/types": "^0.1.71",
    "babylon-lite-explorer": "^0.5.0",
    "preact": "^10.29.7",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
