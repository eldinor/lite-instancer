{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts", "src/outline.ts"],
  "out": "docs/api",
  "readme": "docs/README.md",
  "name": "@litools/instancer",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "categorizeByGroup": true,
  "requiredToBeDocumented": ["Function"],
