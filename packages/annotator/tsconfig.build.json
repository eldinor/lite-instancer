{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@litools/annotator": ["./src/index.ts"],
      "@litools/annotator/html": ["./src/html.ts"],
      "@litools/annotator/instancer": ["./src/instancer.ts"],
      "@litools/instancer": ["./build-types/instancer-peer.d.ts"]
    }
  },
  "include": ["src"]
}
