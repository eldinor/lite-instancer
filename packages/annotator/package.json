{
  "name": "@litools/annotator",
  "version": "0.1.2",
  "description": "Spatial HTML labels and markers for Babylon Lite meshes and stable Instancer IDs.",
  "homepage": "https://github.com/eldinor/lite-instancer/tree/main/packages/annotator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eldinor/lite-instancer.git",
    "directory": "packages/annotator"
  },
  "bugs": {
    "url": "https://github.com/eldinor/lite-instancer/issues"
  },
  "keywords": [
    "babylonjs",
    "babylon-lite",
    "annotations",
    "labels",
    "markers",
    "collision",
    "occlusion",
    "instancing",
    "spatial-ui",
    "webgpu",
    "3d"
  ],
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Andrei Stepanov",
    "email": "eldinor@gmail.com",
    "url": "https://babylonpress.org/"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./html": {
      "types": "./dist/html.d.ts",
      "import": "./dist/html.js"
    },
    "./instancer": {
      "types": "./dist/instancer.d.ts",
      "import": "./dist/instancer.js"
    },
    "./babylon-occlusion": {
      "types": "./dist/babylon-occlusion.d.ts",
      "import": "./dist/babylon-occlusion.js"
    }
  },
  "files": [
    "dist",
    "API.md",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev:test": "vite --config vite.browser.config.ts --host 127.0.0.1",
    "examples:dev": "vite --config vite.examples.config.ts --host 0.0.0.0",
    "examples:build": "vite build --config vite.examples.config.ts",
    "examples:preview": "vite preview --config vite.examples.config.ts --host 0.0.0.0",
    "test": "vitest run",
    "test:browser": "node ../../node_modules/@playwright/test/cli.js test",
    "typecheck": "tsc --noEmit",
    "release:check": "npm run typecheck && npm test && npm run build && npm run examples:build && npm run test:browser",
    "prepublishOnly": "npm run release:check"
  },
  "peerDependencies": {
    "@babylonjs/lite": "^1.13.0",
    "@litools/instancer": "^0.6.0"
  },
  "peerDependenciesMeta": {
    "@litools/instancer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babylonjs/lite": "^1.13.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^26.1.1",
    "@webgpu/types": "^0.1.71",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
