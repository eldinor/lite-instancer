{
  "name": "@litools/interacter",
  "version": "0.1.0",
  "description": "Click, hover, and pointer interaction utilities for Babylon Lite meshes.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
    "files": [
      "dist",
      "CHANGELOG.md",
      "README.md",
      "LICENSE"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "examples:dev": "npm run build && vite --config vite.examples.config.ts --host 0.0.0.0",
    "examples:build": "npm run build && vite build --config vite.examples.config.ts",
    "examples:preview": "vite preview --config vite.examples.config.ts --host 0.0.0.0",
    "pack:check": "npm pack --dry-run --ignore-scripts",
    "prepublishOnly": "npm run typecheck && npm test && npm run build && npm run pack:check"
  },
  "peerDependencies": {
    "@babylonjs/lite": "^1.13.0"
  },
  "devDependencies": {
    "@babylonjs/lite": "^1.13.0",
    "@types/node": "^26.1.1",
    "@webgpu/types": "^0.1.71",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
